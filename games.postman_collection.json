                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"title\": \"Elden Ring\",\n    \"genre\": \"RPG\",\n    \"platform\": \"PC\",\n    \"price\": 59.99\n}"
                }
            }
        }
    ]
}